{
    "name": "storefront_002",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "scripts": {
        "build": "shopify hydrogen build --codegen",
        "dev": "shopify hydrogen dev --codegen",
        "preview": "shopify hydrogen preview --build",
        "lint": "eslint --no-error-on-unmatched-pattern .",
        "typecheck": "react-router typegen && tsc --noEmit",
        "codegen": "shopify hydrogen codegen && react-router typegen",
        "deploy": "bun run deploy:workers",
        "deploy:workers": "bun run build && wrangler deploy",
        "deploy:workers:dry": "bun run build && wrangler deploy --dry-run",
        "dev:workers": "bun run build && wrangler dev",
        "cf-typegen": "wrangler types"
    },
